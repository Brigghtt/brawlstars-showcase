# Supercell 官方 Brawl Stars API Token
# 在服务器上部署时，需将本文件复制为 .env.local 并填入你的 JWT token
# 注意：Supercell API 会校验请求来源 IP，请确保服务器公网 IP 与开发者后台白名单一致
BRAWL_API_TOKEN=eyJ0eXAiOiJKV1Qi...

# 数据库连接（SQLite 文件）
DATABASE_URL="file:./prisma/dev.db"

# Auth.js 加密密钥（生产环境请使用随机生成的强密钥）
# 生成方式：npx auth secret
AUTH_SECRET=your-auth-secret-here
