generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String         @id @default(cuid())
  name          String?
  nickname      String?        // 用户自定义昵称
  email         String         @unique
  emailVerified DateTime?
  image         String?        // OAuth / Gravatar 头像（保留）
  avatarUrl     String?        // 用户从英雄表情中选择的头像
  password      String?        // 邮箱密码登录使用（Credentials Provider）
  accounts      Account[]
  sessions      Session[]
  favorites     FavoriteMap[]
  favoriteHeroes FavoriteHero[]
  viewHistory   ViewHistory[]
  favoritePins  FavoritePin[]
  followedTeams FollowedTeam[]
  followedPlayers FollowedPlayer[]
  eventFavorites EventFavorite[]
  predictions  Prediction[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FavoriteMap {
  id        String   @id @default(cuid())
  userId    String
  mapName   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mapName])
  @@index([userId])
}

model FavoriteHero {
  id        String   @id @default(cuid())
  userId    String
  heroId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, heroId])
  @@index([userId])
}

model ViewHistory {
  id        String   @id @default(cuid())
  userId    String
  itemType  String   // 'map' | 'hero' | 'mode'
  itemId    String   // 地图名 / 英雄 id / 模式 id
  title     String   // 展示标题（中文）
  imageUrl  String?  // 预览图
  viewedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
  @@index([userId, viewedAt])
  @@index([userId, itemType])
}

model FavoritePin {
  id        String   @id @default(cuid())
  userId    String
  pinUrl    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pinUrl])
  @@index([userId])
}

model FollowedTeam {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
}

model FollowedPlayer {
  id        String   @id @default(cuid())
  userId    String
  playerId  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, playerId])
  @@index([userId])
}

model EventFavorite {
  id        String   @id @default(cuid())
  userId    String
  itemType  String   // 'team' | 'player' | 'match'
  itemId    String
  title     String
  imageUrl  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
  @@index([userId])
}

model Prediction {
  id              String    @id @default(cuid())
  userId          String
  matchId         String    // 对应 Tournament.id
  predictedTeam   String    // 'A' | 'B'
  createdAt       DateTime  @default(now())
  actualWinner    String?   // 'A' | 'B' | 'draw'
  isCorrect       Boolean?
  resolvedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([userId])
}
